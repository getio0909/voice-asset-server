# Safe local-development defaults. Replace the password outside local development.
VOICEASSET_BRAND_NAME=VoiceAsset
VOICEASSET_HTTP_ADDR=:8080
VOICEASSET_SHUTDOWN_TIMEOUT=10s
VOICEASSET_PUBLIC_ORIGIN=http://localhost:8080
VOICEASSET_COOKIE_SECURE=false

POSTGRES_DB=voiceasset
POSTGRES_USER=voiceasset
POSTGRES_PASSWORD=voiceasset-development-only
DATABASE_URL=postgres://voiceasset:voiceasset-development-only@localhost:5432/voiceasset?sslmode=disable
# Compose uses its service hostname. Keep this URL aligned with the three
# POSTGRES_* values; percent-encode reserved password characters in this URL.
VOICEASSET_COMPOSE_DATABASE_URL=postgres://voiceasset:voiceasset-development-only@postgres:5432/voiceasset?sslmode=disable

# Local object storage for uploads and immutable ASR provider responses.
VOICEASSET_STORAGE_BACKEND=local
VOICEASSET_STORAGE_PATH=./var/objects
# For S3-compatible object storage, set VOICEASSET_STORAGE_BACKEND=s3 and the
# fields below. HTTPS is required except for loopback development endpoints;
# leave static credentials empty to use the AWS SDK default credential chain.
# VOICEASSET_S3_ENDPOINT=https://objects.example.test
# VOICEASSET_S3_REGION=us-east-1
# VOICEASSET_S3_BUCKET=voiceasset-private
# VOICEASSET_S3_PREFIX=voiceasset
# VOICEASSET_S3_ACCESS_KEY_ID=
# VOICEASSET_S3_SECRET_ACCESS_KEY=
# VOICEASSET_S3_SESSION_TOKEN=
# VOICEASSET_S3_FORCE_PATH_STYLE=false
# VOICEASSET_S3_CA_FILE=
# VOICEASSET_S3_TEMP_PATH=./var/s3-temp
VOICEASSET_FFMPEG_PATH=ffmpeg
# Optional OTLP/HTTP tracing. HTTPS is required for non-loopback collectors;
# leave empty to disable export. A base URL receives the standard /v1/traces
# path automatically.
VOICEASSET_OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional. Required only when storing real provider credentials. Generate a
# unique 32-byte key and encode it as standard base64; never commit the value.
VOICEASSET_PROFILE_MASTER_KEY=

# Optional live ASR contract tests. Keep all values empty in source control.
# VOICEASSET_LIVE_ASR_AUDIO must be a short local 16 kHz fixture.
VOICEASSET_LIVE_ASR=0
VOICEASSET_LIVE_ASR_AUDIO=
VOICEASSET_LIVE_ASR_LANGUAGE=en-US
VOICEASSET_LIVE_ASR_HOTWORDS=0
TENCENT_ASR_APP_ID=
TENCENT_ASR_SECRETID=
TENCENT_ASR_SECRETKEY=
ALIYUN_ASR_APP_KEY=
ALIYUN_ASR_ACCESS_TOKEN=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
